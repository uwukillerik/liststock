# Скопируйте в .env и при необходимости измените значения.
# Строка подключения PostgreSQL (база будет создана скриптом db:setup, если её ещё нет).
DATABASE_URL=postgresql://postgres:ВАШ_ПАРОЛЬ@127.0.0.1:5432/sclad

# Секрет для JWT (в продакшене задайте длинную случайную строку).
JWT_SECRET=замените-на-случайную-строку

# Опционально при первом запуске db:setup (иначе используются значения по умолчанию из скрипта).
# SEED_ADMIN_PASSWORD=
# SEED_WORKER_PASSWORD=

# Отключить демо-товары при инициализации: SEED_DEMO_PRODUCTS=0

# Порт production-сервера (pnpm start / node dist/server/node-build.mjs)
# PORT=8080
